# cook your dish here
t = int(input())

for i in range(t):
    n,k = map(int,input().split())
    a = list(map(int,input().split()))
    
    total = sum(a)
    limit = 2*k - total
    
    ans = 0
    for i in range(n):
        for j in range(i+1,n):
            if a[i] + a[j]> limit:
                ans += 1
    print(ans)
